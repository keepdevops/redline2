# syntax=docker/dockerfile:1
# VarioSync Web-Based GUI - Bytecode Optimized Version
# Multi-stage build with pre-compiled Python bytecode and minified JavaScript/CSS for production

# ============================================
# Stage 1: Builder - Install dependencies and compile bytecode
# ============================================
FROM python:3.11-slim AS builder

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=0 \
    PYTHONOPTIMIZE=2 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install build dependencies (including Node.js for JavaScript minification)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
WORKDIR /app
COPY requirements.txt .

# Install Python dependencies with cache mount
# Using requirements.txt for consistent dependency management
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip>=25.3 setuptools wheel && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . /app

# Install npm packages for JavaScript/CSS minification
RUN npm install -g terser cssnano-cli && \
    echo "✅ Installed minification tools"

# Minify JavaScript and CSS assets
RUN echo "🔨 Minifying JavaScript and CSS assets..." && \
    JS_DIR="redline/web/static/js" && \
    CSS_DIR="redline/web/static/css" && \
    # Minify JavaScript files
    if [ -f "$JS_DIR/main.js" ]; then \
        npx terser "$JS_DIR/main.js" --compress --mangle --output "$JS_DIR/main.min.js" && \
        echo "✅ Minified main.js"; \
    fi && \
    if [ -f "$JS_DIR/color-customizer.js" ]; then \
        npx terser "$JS_DIR/color-customizer.js" --compress --mangle --output "$JS_DIR/color-customizer.min.js" && \
        echo "✅ Minified color-customizer.js"; \
    fi && \
    if [ -f "$JS_DIR/virtual-scroll.js" ]; then \
        npx terser "$JS_DIR/virtual-scroll.js" --compress --mangle --output "$JS_DIR/virtual-scroll.min.js" && \
        echo "✅ Minified virtual-scroll.js"; \
    fi && \
    if [ -f "$JS_DIR/date-formatter.js" ]; then \
        npx terser "$JS_DIR/date-formatter.js" --compress --mangle --output "$JS_DIR/date-formatter.min.js" && \
        echo "✅ Minified date-formatter.js"; \
    fi && \
    if [ -f "$JS_DIR/payments.js" ]; then \
        npx terser "$JS_DIR/payments.js" --compress --mangle --output "$JS_DIR/payments.min.js" && \
        echo "✅ Minified payments.js"; \
    fi && \
    if [ -f "$JS_DIR/balance_tracker.js" ]; then \
        npx terser "$JS_DIR/balance_tracker.js" --compress --mangle --output "$JS_DIR/balance_tracker.min.js" && \
        echo "✅ Minified balance_tracker.js"; \
    fi && \
    # Minify CSS files
    if [ -f "$CSS_DIR/main.css" ]; then \
        npx cssnano "$CSS_DIR/main.css" "$CSS_DIR/main.min.css" && \
        echo "✅ Minified main.css"; \
    fi && \
    if [ -f "$CSS_DIR/themes.css" ]; then \
        npx cssnano "$CSS_DIR/themes.css" "$CSS_DIR/themes.min.css" && \
        echo "✅ Minified themes.css"; \
    fi && \
    if [ -f "$CSS_DIR/virtual-scroll.css" ]; then \
        npx cssnano "$CSS_DIR/virtual-scroll.css" "$CSS_DIR/virtual-scroll.min.css" && \
        echo "✅ Minified virtual-scroll.css"; \
    fi && \
    if [ -f "$CSS_DIR/color-customizer.css" ]; then \
        npx cssnano "$CSS_DIR/color-customizer.css" "$CSS_DIR/color-customizer.min.css" && \
        echo "✅ Minified color-customizer.css"; \
    fi && \
    echo "✅ JavaScript and CSS minification complete"

# Skip bytecode compilation - causes issues with TensorFlow, Celery, and other packages
# that require docstrings. Keep source files for production.
# Alternative: Use Python's built-in .pyc generation at runtime (PYTHONDONTWRITEBYTECODE=0)
RUN echo "⚠️  Bytecode compilation skipped to avoid TensorFlow/Celery compatibility issues" && \
    echo "✅ Source files preserved for production (Python will generate .pyc at runtime)" && \
    find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true

# ============================================
# Stage 2: Runtime - Minimal production image
# ============================================
FROM python:3.11-slim AS runtime

# Set environment variables
# Note: JWT Authentication and Stripe Subscription environment variables should be set at runtime:
# 
# REQUIRED - Supabase Authentication (JWT):
# - SUPABASE_URL (Supabase project URL)
# - SUPABASE_SERVICE_KEY (Supabase service role key)
# - SUPABASE_JWT_SECRET (JWT secret for token validation)
#
# REQUIRED - Stripe Subscription Service:
# - STRIPE_SECRET_KEY (Stripe secret key for API calls)
# - STRIPE_PUBLISHABLE_KEY (Stripe publishable key for frontend)
# - STRIPE_WEBHOOK_SECRET (Stripe webhook signing secret)
# - STRIPE_PRICE_ID_METERED (Stripe price ID for metered billing subscription)
#
# OPTIONAL - Cloud Storage (S3/R2):
# - USE_S3_STORAGE (set to 'true' to enable S3/R2 storage, default: true)
# 
# For Cloudflare R2:
# - S3_ENDPOINT_URL (R2 endpoint: https://<account-id>.r2.cloudflarestorage.com)
# - S3_BUCKET (R2 bucket name)
# - S3_ACCESS_KEY (R2 API Token)
# - S3_SECRET_KEY (R2 API Secret)
# - S3_REGION (set to 'auto' for R2)
#
# For AWS S3:
# - S3_ENDPOINT_URL (leave empty or use standard S3 endpoint)
# - S3_BUCKET (S3 bucket name)
# - S3_ACCESS_KEY (AWS Access Key ID)
# - S3_SECRET_KEY (AWS Secret Access Key)
# - S3_REGION (AWS region, e.g., us-east-1)
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONOPTIMIZE=2 \
    FLASK_APP=web_app.py \
    FLASK_ENV=production \
    GUNICORN_WORKERS=1 \
    GUNICORN_THREADS=4 \
    GUNICORN_TIMEOUT=120 \
    VARIOSYNC_VERSION=2.1.0 \
    CURL_IMPERSONATE=0

# Install runtime dependencies only
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create app user for security (don't run as root)
RUN useradd -m -u 1000 -s /bin/bash appuser

# Set working directory
WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy compiled application code (bytecode only, no source)
COPY --chown=appuser:appuser --from=builder /app /app

# Create necessary directories
RUN mkdir -p /app/data /app/logs /app/config /app/data/uploads /app/data/user_files && \
    chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Expose web port
EXPOSE 8080

# Healthcheck disabled - causes issues with DuckDB single-worker constraint
# HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
#     CMD curl -f http://localhost:8080/health || exit 1

# Start the web application with Gunicorn (production settings)
CMD ["gunicorn", \
     "--bind", "0.0.0.0:8080", \
     "--workers", "1", \
     "--threads", "4", \
     "--timeout", "120", \
     "--worker-class", "gthread", \
     "--access-logfile", "-", \
     "--error-logfile", "-", \
     "web_app:create_app()"]

# Labels for metadata
LABEL maintainer="VarioSync Team <keepdevops@gmail.com>" \
      version="2.1.0-bytecode" \
      description="VarioSync Financial Analysis - Bytecode Optimized Production Version with Modular Architecture and Subscription Service" \
      architecture="multi-platform" \
      performance="optimized" \
      license="proprietary" \
      service="subscription" \
      features="modular-blueprints,data-cleaning,date-formatting,api-key-masking,custom-apis,payment-integration,stripe-integration,js-minification,css-minification" \
      code-organization="27-modular-blueprints-under-200LOC" \
      optimizations="python-bytecode,javascript-minification,css-minification" \
      build-date="2025-01-27"

